generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Trade {
  id                    String    @id @default(uuid())
  ticker                String
  action                String
  tradeType             String
  filledPrice           Float
  quantity              Float
  sizeUsd               Float
  stopLoss              Float
  takeProfit            Float
  invalidationCondition String?
  confidence            Int
  debateScore           Int
  bullConviction        Int
  bearConviction        Int
  reasoning             String
  closedAt              DateTime?
  closePrice            Float?
  pnlUsd                Float?
  closeReason           String?
  mock                  Boolean   @default(true)
  createdAt             DateTime  @default(now())

  @@index([ticker])
  @@index([createdAt])
  @@index([closedAt])
}

model Config {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CycleLog {
  id          String   @id @default(uuid())
  payload     Json
  ordersCount Int
  alertsCount Int
  durationMs  Int
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

model AgentPrediction {
  id                 String    @id @default(uuid())
  cycleId            String
  ticker             String
  predictedDirection String    // 'BUY' | 'SELL' | 'HOLD'
  confidence         Int
  debateScore        Int
  bullConviction     Int
  bearConviction     Int
  priceAtPrediction  Float
  actualReturn5d     Float?    // rempli 5 jours après
  correct            Boolean?  // basé sur actualReturn5d vs predictedDirection
  resolvedAt         DateTime?
  createdAt          DateTime  @default(now())

  @@index([ticker])
  @@index([createdAt])
  @@index([resolvedAt])
}

model TickerSnapshot {
  id        String   @id @default(uuid())
  ticker    String
  interval  String
  time      DateTime
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Float?
  source    String
  createdAt DateTime @default(now())

  @@index([ticker, time])
  @@index([ticker, interval, time])
}

model TickerNote {
  id         String   @id @default(uuid())
  ticker     String
  noteType   String
  content    String
  confidence Int?
  cycleId    String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([ticker, noteType, createdAt])
  @@index([createdAt])
}

model PreMarketPrep {
  id              String   @id @default(uuid())
  date            String
  ticker          String
  closePrev       Float
  vixPrev         Float?
  macroSummary    String?
  setupSignal     String
  confidence      Int
  reasoning       String
  executedAtOpen  Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([date, ticker])
  @@index([date, setupSignal])
}
