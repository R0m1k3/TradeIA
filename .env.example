# ─── DATABASE ────────────────────────────────────────────────────────────────
DB_PASS=trading123

# ─── LLM PROVIDER ────────────────────────────────────────────────────────────
# "openrouter" (cloud) or "ollama" (local GPU)
LLM_PROVIDER=openrouter

# OpenRouter (https://openrouter.ai)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Ollama (only used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://ollama:11434

# ─── MODEL SELECTION ─────────────────────────────────────────────────────────
# OpenRouter model IDs (when LLM_PROVIDER=openrouter)
MODEL_LIGHT=anthropic/claude-haiku-4-5
MODEL_MID=anthropic/claude-sonnet-4-5
MODEL_STRONG=anthropic/claude-opus-4

# Ollama model IDs (when LLM_PROVIDER=ollama)
# MODEL_LIGHT=qwen2.5:7b
# MODEL_MID=qwen2.5:14b
# MODEL_STRONG=qwen2.5:32b

# ─── MARKET DATA APIs ────────────────────────────────────────────────────────
# Alpha Vantage (https://www.alphavantage.co/support/#api-key)
ALPHA_VANTAGE_KEY=YOUR_ALPHA_VANTAGE_KEY

# Polygon.io (https://polygon.io/dashboard/api-keys)
POLYGON_KEY=YOUR_POLYGON_KEY

# Finnhub (https://finnhub.io/dashboard)
FINNHUB_KEY=YOUR_FINNHUB_KEY

# ─── TRADING SYSTEM ──────────────────────────────────────────────────────────
# Use simulated broker (true = no real money, false = real broker)
MOCK_BROKER=true

# Starting portfolio size in USD
PORTFOLIO_USD=10000

# Maximum daily loss before blocking all new BUY orders (%)
DAILY_LOSS_LIMIT_PCT=3

# Comma-separated list of tickers to trade
WATCHLIST=AAPL,MSFT,GOOGL,AMZN,NVDA,TSLA,META,JPM,BAC,GE

# ─── SECURITY ────────────────────────────────────────────────────────────────
# Password for the POST /api/override/* endpoints
ADMIN_PASSWORD=changeme_in_production
