# ─── DATABASE ────────────────────────────────────────────────────────────────
DB_PASS=trading123

# ─── LLM PROVIDER ────────────────────────────────────────────────────────────
# "openrouter" (cloud) or "ollama" (local GPU)
LLM_PROVIDER=openrouter

# OpenRouter (https://openrouter.ai) — CRITICAL: without this, NO analysis works
OPENROUTER_API_KEY=

# Ollama (only used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://ollama:11434

# ─── MODEL SELECTION ─────────────────────────────────────────────────────────
# OpenRouter model IDs (when LLM_PROVIDER=openrouter)
MODEL_LIGHT=anthropic/claude-haiku-4-5
MODEL_MID=anthropic/claude-sonnet-4-5
MODEL_STRONG=anthropic/claude-opus-4

# Ollama model IDs (when LLM_PROVIDER=ollama)
# MODEL_LIGHT=qwen2.5:7b
# MODEL_MID=qwen2.5:14b
# MODEL_STRONG=qwen2.5:32b

# ─── MARKET DATA APIs ────────────────────────────────────────────────────────
# Polygon.io — volume, options, market snapshot, VIX
# Free tier: 5 calls/min. Stocks Starter ($29/mo): unlimited
# https://polygon.io/dashboard/api-keys
POLYGON_KEY=

# Finnhub — news, sentiment
# Free tier: 60 calls/min
# https://finnhub.io/dashboard
FINNHUB_KEY=

# AlphaVantage — OHLCV intraday, fundamentals
# Free tier: 25 calls/day (useless for production). Premium ($50/mo): 75 calls/min
# https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=

# ─── TRADING SYSTEM ──────────────────────────────────────────────────────────
MOCK_BROKER=true
PORTFOLIO_USD=10000
DAILY_LOSS_LIMIT_PCT=3
WATCHLIST=AAPL,MSFT,GOOGL,AMZN,NVDA,META,TSLA,AVGO,ORCL,ADBE,CRM,INTC,AMD,QCOM,TXN,SBUX,PYPL,BKNG,ISRG,MDLZ,ADP,GILD,VRTX,REGN,MNST,CHTR,LRCX,KLAC,MRVL,PANW,SNPS,CDNS,MRNA,ILMN,BIIB,FTNT,ZS,DDOG,NET,CRWD,ABNB,COIN,PLTR,ARM,GE,COST,CMCSA,NFLX,PEP

# ─── SECURITY ────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=changeme_in_production